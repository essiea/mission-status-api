<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>{{ app_name }}</title>
  <style>
    :root {
      --bg-1: #0f172a;
      --bg-2: #111827;
      --panel: rgba(255, 255, 255, 0.08);
      --panel-strong: rgba(255, 255, 255, 0.12);
      --border: rgba(255, 255, 255, 0.14);
      --text: #f8fafc;
      --muted: #cbd5e1;
      --blue: #60a5fa;
      --cyan: #22d3ee;
      --green: #34d399;
      --purple: #a78bfa;
      --yellow: #fbbf24;
      --shadow: 0 18px 60px rgba(0, 0, 0, 0.35);
    }

    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      min-height: 100vh;
      font-family: Inter, Segoe UI, Arial, sans-serif;
      color: var(--text);
      background:
        radial-gradient(circle at top left, rgba(96, 165, 250, 0.22), transparent 30%),
        radial-gradient(circle at top right, rgba(34, 211, 238, 0.18), transparent 28%),
        radial-gradient(circle at bottom left, rgba(167, 139, 250, 0.16), transparent 30%),
        linear-gradient(135deg, var(--bg-1), var(--bg-2));
      padding: 28px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .shell {
      width: 100%;
      max-width: 1200px;
      border-radius: 28px;
      overflow: hidden;
      background: rgba(15, 23, 42, 0.72);
      border: 1px solid var(--border);
      box-shadow: var(--shadow);
      backdrop-filter: blur(16px);
    }

    .hero {
      padding: 34px 34px 18px;
      border-bottom: 1px solid rgba(255,255,255,0.08);
      display: flex;
      justify-content: space-between;
      gap: 20px;
      flex-wrap: wrap;
    }

    .hero-left {
      max-width: 760px;
    }

    .status-badge {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      padding: 8px 16px;
      border-radius: 999px;
      background: rgba(52, 211, 153, 0.12);
      border: 1px solid rgba(52, 211, 153, 0.25);
      color: #dcfce7;
      font-size: 14px;
      font-weight: 700;
      margin-bottom: 18px;
    }

    .pulse {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      background: var(--green);
      box-shadow: 0 0 14px rgba(52, 211, 153, 0.9);
    }

    h1 {
      margin: 0 0 12px;
      font-size: 42px;
      line-height: 1.05;
      letter-spacing: -0.03em;
    }

    .subtitle {
      margin: 0;
      color: var(--muted);
      font-size: 17px;
      line-height: 1.7;
    }

    .hero-card {
      min-width: 250px;
      padding: 18px 20px;
      border-radius: 18px;
      background: linear-gradient(135deg, rgba(96, 165, 250, 0.16), rgba(34, 211, 238, 0.08));
      border: 1px solid rgba(96, 165, 250, 0.22);
      align-self: flex-start;
    }

    .hero-card .label {
      color: var(--muted);
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      margin-bottom: 8px;
    }

    .hero-card .value {
      font-size: 24px;
      font-weight: 800;
    }

    .grid {
      display: grid;
      grid-template-columns: 1.2fr 0.8fr;
      gap: 22px;
      padding: 26px 34px 34px;
    }

    .panel {
      background: var(--panel);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 22px;
      padding: 22px;
    }

    .panel h2 {
      margin: 0 0 18px;
      font-size: 20px;
    }

    .stats {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 14px;
    }

    .stat {
      border-radius: 18px;
      padding: 16px;
      background: var(--panel-strong);
      border: 1px solid rgba(255,255,255,0.08);
    }

    .stat .k {
      font-size: 12px;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.08em;
      margin-bottom: 8px;
    }

    .stat .v {
      font-size: 20px;
      font-weight: 800;
      word-break: break-word;
    }

    .cards {
      display: grid;
      gap: 12px;
    }

    .endpoint {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 14px;
      padding: 16px 18px;
      border-radius: 18px;
      background: var(--panel-strong);
      border: 1px solid rgba(255,255,255,0.08);
      text-decoration: none;
      color: var(--text);
      transition: transform 0.18s ease, border-color 0.18s ease, background 0.18s ease;
    }

    .endpoint:hover {
      transform: translateY(-2px);
      border-color: rgba(96, 165, 250, 0.45);
      background: rgba(96, 165, 250, 0.10);
    }

    .endpoint-main {
      font-weight: 800;
      margin-bottom: 4px;
    }

    .endpoint-sub {
      font-size: 14px;
      color: var(--muted);
    }

    .arrow {
      font-size: 22px;
      color: var(--blue);
      flex-shrink: 0;
    }

    .live-list {
      display: grid;
      gap: 12px;
    }

    .live-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
      padding: 14px 16px;
      border-radius: 16px;
      background: var(--panel-strong);
      border: 1px solid rgba(255,255,255,0.08);
    }

    .live-pill {
      padding: 7px 12px;
      border-radius: 999px;
      font-size: 13px;
      font-weight: 800;
      border: 1px solid transparent;
    }

    .ok {
      background: rgba(52, 211, 153, 0.12);
      color: #dcfce7;
      border-color: rgba(52, 211, 153, 0.25);
    }

    .warn {
      background: rgba(251, 191, 36, 0.12);
      color: #fef3c7;
      border-color: rgba(251, 191, 36, 0.25);
    }

    .footer {
      padding: 0 34px 28px;
      color: var(--muted);
      font-size: 13px;
    }

    .accent-blue { color: var(--blue); }
    .accent-cyan { color: var(--cyan); }
    .accent-purple { color: var(--purple); }
    .accent-green { color: var(--green); }
    .accent-yellow { color: var(--yellow); }

    @media (max-width: 960px) {
      .grid {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 640px) {
      body {
        padding: 16px;
      }

      .hero,
      .grid {
        padding-left: 20px;
        padding-right: 20px;
      }

      .stats {
        grid-template-columns: 1fr;
      }

      h1 {
        font-size: 34px;
      }
    }
  </style>
</head>
<body>
  <div class="shell">
    <section class="hero">
      <div class="hero-left">
        <div class="status-badge">
          <span class="pulse"></span>
          Platform Live and Healthy
        </div>
        <h1>
          {{ app_name }}
          <span class="accent-cyan">Dashboard</span>
        </h1>
        <p class="subtitle">
          A polished multi-cloud application landing page built for Kubernetes deployment demos,
          interview walkthroughs, and production-style platform presentations.
        </p>
      </div>

      <div class="hero-card">
        <div class="label">Active Deployment Target</div>
        <div class="value">{{ cloud_provider|upper }}</div>
      </div>
    </section>

    <section class="grid">
      <div class="panel">
        <h2>Deployment Overview</h2>
        <div class="stats">
          <div class="stat">
            <div class="k">Environment</div>
            <div class="v accent-blue">{{ env }}</div>
          </div>
          <div class="stat">
            <div class="k">Version</div>
            <div class="v accent-cyan" id="versionValue">{{ version }}</div>
          </div>
          <div class="stat">
            <div class="k">Cloud Provider</div>
            <div class="v accent-purple">{{ cloud_provider|upper }}</div>
          </div>
          <div class="stat">
            <div class="k">Region</div>
            <div class="v accent-green">{{ cloud_region }}</div>
          </div>
          <div class="stat">
            <div class="k">Cluster</div>
            <div class="v accent-yellow">{{ cluster_name }}</div>
          </div>
          <div class="stat">
            <div class="k">Deployed At</div>
            <div class="v">{{ deployed_at }}</div>
          </div>
        </div>

        <h2 style="margin-top: 26px;">API Endpoints</h2>
        <div class="cards">
          <a class="endpoint" href="/health">
            <div>
              <div class="endpoint-main">/health</div>
              <div class="endpoint-sub">Liveness and readiness probe endpoint</div>
            </div>
            <div class="arrow">→</div>
          </a>

          <a class="endpoint" href="/status">
            <div>
              <div class="endpoint-main">/status</div>
              <div class="endpoint-sub">Operational metadata for this deployment</div>
            </div>
            <div class="arrow">→</div>
          </a>

          <a class="endpoint" href="/version">
            <div>
              <div class="endpoint-main">/version</div>
              <div class="endpoint-sub">Current deployed application version</div>
            </div>
            <div class="arrow">→</div>
          </a>
        </div>
      </div>

      <div class="panel">
        <h2>Live Service Signals</h2>
        <div class="live-list">
          <div class="live-item">
            <span>Health Endpoint</span>
            <span id="healthStatus" class="live-pill warn">Checking...</span>
          </div>

          <div class="live-item">
            <span>Service Status</span>
            <span id="serviceStatus" class="live-pill warn">Checking...</span>
          </div>

          <div class="live-item">
            <span>Cloud Target</span>
            <span id="cloudStatus" class="live-pill ok">{{ cloud_provider|upper }}</span>
          </div>

          <div class="live-item">
            <span>Cluster</span>
            <span id="clusterStatus" class="live-pill ok">{{ cluster_name }}</span>
          </div>
        </div>
      </div>
    </section>

    <div class="footer">
      Designed for interview presentation, demo walkthroughs, and production-style multi-cloud showcases.
    </div>
  </div>

  <script>
    async function refreshDashboard() {
      try {
        const [healthResp, statusResp, versionResp] = await Promise.all([
          fetch('/health'),
          fetch('/status'),
          fetch('/version')
        ]);

        const healthData = await healthResp.json();
        const statusData = await statusResp.json();
        const versionData = await versionResp.json();

        const healthEl = document.getElementById('healthStatus');
        const serviceEl = document.getElementById('serviceStatus');
        const cloudEl = document.getElementById('cloudStatus');
        const clusterEl = document.getElementById('clusterStatus');
        const versionEl = document.getElementById('versionValue');

        healthEl.textContent = healthData.status === 'ok' ? 'Healthy' : 'Degraded';
        healthEl.className = healthData.status === 'ok'
          ? 'live-pill ok'
          : 'live-pill warn';

        serviceEl.textContent = statusData.status || 'Unknown';
        serviceEl.className = statusData.status === 'running'
          ? 'live-pill ok'
          : 'live-pill warn';

        cloudEl.textContent = (statusData.cloud_provider || '{{ cloud_provider }}').toUpperCase();
        clusterEl.textContent = statusData.cluster || '{{ cluster_name }}';
        versionEl.textContent = versionData.version || '{{ version }}';
      } catch (error) {
        document.getElementById('healthStatus').textContent = 'Unavailable';
        document.getElementById('serviceStatus').textContent = 'Unavailable';
        document.getElementById('healthStatus').className = 'live-pill warn';
        document.getElementById('serviceStatus').className = 'live-pill warn';
      }
    }

    refreshDashboard();
    setInterval(refreshDashboard, 10000);
  </script>
</body>
</html>
